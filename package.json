{
  "name": "cloud-computing-learning-assistant",
  "version": "1.0.0",
  "description": "Cloud Computing Learning Assistant using Adaptive RAG",
  "scripts": {
    "install:backend": "cd backend && npm.cmd install",
    "install:frontend": "cd frontend && npm.cmd install",
    "postinstall": "npm.cmd run install:backend && npm.cmd run install:frontend",
    "dev:backend": "cd backend && npm.cmd run dev",
    "dev:frontend": "cd frontend && npm.cmd run dev",
    "dev": "concurrently \"npm.cmd run dev:backend\" \"npm.cmd run dev:frontend\"",
    "build": "cd frontend && npm.cmd run build",
    "start": "cd backend && npm.cmd start"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["cloud-computing", "rag", "ai", "learning-assistant"],
  "author": "Keerthi Sri",
  "license": "MIT"
}
